{
  "appId": "com.coffeebean.vault",
  "appName": "豆仓",
  "webDir": "www",
  "backgroundColor": "#1a1412",
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#1a1412"
  },
  "plugins": {
