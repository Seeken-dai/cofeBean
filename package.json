{
  "name": "coffee-vault-android",
  "version": "2.1.4",
  "private": true,
  "description": "豆仓 - 本地优先的咖啡豆管理 Android App",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "bump-version": "node scripts/bump-version.mjs",
    "cap:sync": "cap sync android",
    "android:debug": "cap sync android && cd android && .\\gradlew.bat assembleDebug",
    "android:release": "cap sync android && cd android && .\\gradlew.bat assembleRelease",
    "assets": "capacitor-assets generate --android"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "8.1.0",
    "@capacitor/android": "8.4.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "8.4.1",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/share": "8.0.1",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@capawesome/capacitor-file-picker": "8.0.3",
    "jsqr": "^1.4.0",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "8.4.1"
  }
}
